From d71853aca405851cead25025f3d69d594c8171e2 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?J=C3=B6rg=20Thalheim?= <joerg@thalheim.io>
Date: Fri, 3 Apr 2026 11:40:16 +0200
Subject: [PATCH] serialize git config writes across concurrent processes
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Multiple workmux processes creating worktrees in the same repo race on
.git/config.lock and fail with "could not lock config file". Git
acquires this lock with O_EXCL and no retry; each `worktree add -b`
plus our metadata writes hits it ~6 times.

Fix: hold an advisory flock on <git-common-dir>/workmux.lock around the
config-writing git calls. The lock file lives in git-common-dir so all
worktrees of one repo contend on the same file.

Signed-off-by: Jörg Thalheim <joerg@thalheim.io>
---
 src/git/lock.rs        | 36 ++++++++++++++++++++++++++++++++++++
 src/git/mod.rs         |  2 ++
 src/workflow/create.rs |  9 ++++++++-
 3 files changed, 46 insertions(+), 1 deletion(-)
 create mode 100644 src/git/lock.rs

diff --git a/src/git/lock.rs b/src/git/lock.rs
new file mode 100644
index 0000000..2c22718
--- /dev/null
+++ b/src/git/lock.rs
@@ -0,0 +1,36 @@
+//! Cross-process lock for serializing `.git/config` writes.
+//!
+//! `git config` acquires `config.lock` with `O_EXCL` and no retry, so
+//! concurrent workmux processes racing to create worktrees in the same repo
+//! fail with "could not lock config file". We hold an advisory flock on a
+//! sidecar file around the config-writing git calls to serialize them.
+
+use anyhow::{Context, Result};
+use std::fs::File;
+use std::path::Path;
+
+#[cfg(unix)]
+use nix::fcntl::{Flock, FlockArg};
+
+/// RAII guard. Lock released on drop.
+#[cfg(unix)]
+pub type ConfigLock = Flock<File>;
+#[cfg(not(unix))]
+pub struct ConfigLock(File);
+
+/// Block until we hold an exclusive lock on `<git_common_dir>/workmux.lock`.
+/// Pass the git-common-dir so all worktrees of one repo share the same lock.
+pub fn lock_config_writes(git_common_dir: &Path) -> Result<ConfigLock> {
+    let lock_path = git_common_dir.join("workmux.lock");
+    let file = File::create(&lock_path)
+        .with_context(|| format!("Failed to create lock file {}", lock_path.display()))?;
+
+    #[cfg(unix)]
+    return Flock::lock(file, FlockArg::LockExclusive)
+        .map_err(|(_, e)| e)
+        .with_context(|| format!("flock({}) failed", lock_path.display()));
+
+    // No-op on non-Unix; the race hasn't been reported there.
+    #[cfg(not(unix))]
+    return Ok(ConfigLock(file));
+}
diff --git a/src/git/mod.rs b/src/git/mod.rs
index 0de3b11..c1c73f1 100644
--- a/src/git/mod.rs
+++ b/src/git/mod.rs
@@ -1,5 +1,6 @@
 mod branch;
 mod cache;
+mod lock;
 mod merge;
 mod remote;
 mod repo;
@@ -9,6 +10,7 @@ mod worktree;
 
 pub use branch::*;
 pub use cache::*;
+pub use lock::*;
 pub use merge::*;
 pub use remote::*;
 pub use repo::*;
diff --git a/src/workflow/create.rs b/src/workflow/create.rs
index caceec6..07dd3b7 100644
--- a/src/workflow/create.rs
+++ b/src/workflow/create.rs
@@ -333,7 +333,11 @@ pub fn create(context: &WorkflowContext, args: CreateArgs) -> Result<CreateResul
         })?;
     }
 
-    // Create worktree
+    // The next few git calls write .git/config; git's config.lock has no
+    // retry, so concurrent workmux processes race on it. Serialize them.
+    let git_common_dir = git::get_git_common_dir()?;
+    let _config_lock = git::lock_config_writes(&git_common_dir)?;
+
     info!(
         branch = branch_name,
         path = %worktree_path.display(),
@@ -384,6 +388,9 @@ pub fn create(context: &WorkflowContext, args: CreateArgs) -> Result<CreateResul
         "create:stored tmux mode in git config"
     );
 
+    // Config writes done; let other workmux processes proceed.
+    drop(_config_lock);
+
     // Write prompt file to worktree if provided
     let prompt_file_path = if let Some(p) = prompt {
         Some(setup::write_prompt_file(
