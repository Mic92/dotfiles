From f14d92c550e398417672ce08ed4f1c3bada99cf2 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?J=C3=B6rg=20Thalheim?= <joerg@thalheim.io>
Date: Tue, 21 Apr 2026 19:50:27 +0200
Subject: [PATCH] BluetoothService: unblock rfkill when enabling a blocked
 adapter
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

quickshell's BluetoothAdapter.setEnabled() bails out with "Cannot enable
adapter because it is blocked by rfkill" and never writes the Powered
property when the adapter is in the Blocked state. This leaves the
bluetooth toggle dead after a partial airplane-mode exit (e.g. the user
re-enables wifi via NetworkManager but bluetooth stays soft-blocked, and
systemd-rfkill happily persists that across reboots).

logind hands the active seat user rw on /dev/rfkill, so we can lift the
soft block ourselves and power the adapter via bluetoothctl without any
privilege escalation.

Signed-off-by: Jörg Thalheim <joerg@thalheim.io>
---
 Services/Networking/BluetoothService.qml | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/Services/Networking/BluetoothService.qml b/Services/Networking/BluetoothService.qml
index 563591861..4ccf00df7 100644
--- a/Services/Networking/BluetoothService.qml
+++ b/Services/Networking/BluetoothService.qml
@@ -153,6 +153,16 @@ Singleton {
       Logger.d("Bluetooth", "Enable/Disable skipped: no adapter");
       return;
     }
+    // quickshell's BluetoothAdapter.setEnabled() refuses to write Powered
+    // while the adapter is rfkill-blocked, so a partial airplane-mode exit
+    // (wifi unblocked, bluetooth still blocked) leaves the toggle dead.
+    // Lift the soft block ourselves; logind grants the seat user rw on
+    // /dev/rfkill so no privilege escalation is needed.
+    if (state && adapter.state === BluetoothAdapter.Blocked) {
+      Logger.i("Bluetooth", "Adapter rfkill-blocked, unblocking");
+      Quickshell.execDetached(["sh", "-c", "rfkill unblock bluetooth && bluetoothctl power on"]);
+      return;
+    }
     try {
       adapter.enabled = state;
       Logger.i("Bluetooth", "SetBluetoothEnabled", state);
-- 
2.53.0

